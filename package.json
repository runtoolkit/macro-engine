    "./queue": "./src/queue.js",
    "./fiber": "./src/fiber.js",
    "./batch": "./src/batch.js",
    "./state": "./src/state.js",
    "./flag": "./src/flag.js",
    "./config": "./src/config.js",
    "./rate-limit": "./src/rate-limit.js",
    "./math": "./src/math.js",
    "./string": "./src/string.js",
    "./log": "./src/log.js"
